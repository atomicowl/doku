# Copy to .env and fill in — all three are required (no built-in defaults).
# Real environment variables take precedence over values in .env.

# LLM provider API key
DOKU_API_KEY=sk-or-...

# Provider base URL
DOKU_API_BASE=https://openrouter.ai/api/v1

# Model id (may also be passed as --model, which wins)
DOKU_MODEL=openrouter:z-ai/glm-5.2

# Optional: with openai:* models, use the plain Chat Completions API instead
# of the OpenAI Responses API (for vLLM/Ollama/gateway endpoints).
# DOKU_CHAT_COMPLETIONS=1
