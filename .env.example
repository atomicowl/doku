# Copy to .env and fill in — all three are required (no built-in defaults).
# Real environment variables take precedence over values in .env.

# LLM provider API key
DOKU_API_KEY=sk-or-...

# Provider base URL
DOKU_API_BASE=https://openrouter.ai/api/v1

# Model id (may also be passed as --model, which wins)
DOKU_MODEL=openrouter:z-ai/glm-5.2

# Optional sampling temperature. Supported ranges vary by provider/model.
DOKU_MODEL_TEMPERATURE=0.2

# Optional model reasoning effort (for example: low, medium, or high).
# The selected provider and model must support the configured value.
DOKU_MODEL_REASONING_EFFORT=high

# Optional definition roots. Workflow names passed with --workflow are
# resolved beneath DOKU_WORKFLOWS_DIR.
# DOKU_AGENTS_DIR=./agents
# DOKU_WORKFLOWS_DIR=./workflows

# Optional: with openai:* models, use the plain Chat Completions API instead
# of the OpenAI Responses API (for vLLM/Ollama/gateway endpoints).
# DOKU_CHAT_COMPLETIONS=1

# Model rate limit, shared across the orchestrator and all parallel subagents:
# at most DOKU_MODEL_RPS request starts per second, with bursts of up to
# DOKU_MODEL_BURST. Remove both to disable rate limiting.
DOKU_MODEL_RPS=2
DOKU_MODEL_BURST=5

# Max retries per LLM request inside the provider client (0 disables
# retrying). Remove to keep the provider's own default.
DOKU_MODEL_MAX_RETRIES=3
